POSTGRES_PASSWORD=changeme
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
MAX_FILE_SIZE=2
# Swank REPL bind address — use 127.0.0.1 in prod, 0.0.0.0 in dev (default)
SWANK_BIND_ADDRESS=0.0.0.0
# IP allow-list for /admin/ — DEV nginx config only (nginx.conf.template).
# Prod (nginx-ssl.conf.template) no longer uses this: admin auth there is the
# app's password login, and traffic arrives via Cloudflare. Leave as-is for dev.
ADMIN_ALLOWED_IP=0.0.0.0/0
# Domain and TLS (used in prod)
DOMAIN=llmebious.co.uk
CERTBOT_EMAIL=admin@llmebious.co.uk
# Prod only: makes bare `docker-compose ...` include both compose files so you
# never forget the -f flags. Uncomment on the production server.
# COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml
